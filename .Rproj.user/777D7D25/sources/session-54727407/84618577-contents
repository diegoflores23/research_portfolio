perc_avg_columns <- c(3, 11, 27:30)  # Percent average columns 

ny_aggregate <- boroughs %>% # Summarize the data frame
  summarise(
    across(all_of(raw_columns), sum),
    across(all_of(median_columns), median),
    across(all_of(perc_avg_columns), mean)
)
