### Random Forest Model 

Upong splitting datsa into training and testing sets, rhe random forest model can now be run on the training data set. Results are below. 
```{r rf1, echo = FALSE}
incrf <- incacs16 %>%  # Note: the RF model is ran w/ out outliers
  select(-c(1:3, 5, 7:17, 30)) #excluded: fips, state, prison rate, white etc. 
train_index <- sample(seq_len(nrow(incrf)), size = 0.7 * nrow(incrf))
train_data <- incrf[train_index, ]
test_data <- incrf[-train_index, ]
```

``` {r rf2_jail, echo = FALSE}
#training model 
rf1 <- randomForest(total_jail_pop_rate ~ ., data = train_data, ntree = 500, importance = TRUE)
print(rf1)
plot(rf1, main = "Mean Squared Error of Random Forest Model")
```


#### Evaluating the Model: Predicting on test data, Mean squared error (MSE), and R Sqaured 

``` {r rf_evaluating, echo = FALSE}
# Predicting on the test data
predictions <- predict(rf1, test_data)
# Calculate Mean Squared Error (MSE)
mse <- mean((predictions - test_data$total_jail_pop_rate)^2)
print(paste("Mean Squared Error:", mse)) 
# Calculate R-squared
rss <- sum((predictions - test_data$total_jail_pop_rate)^2)
tss <- sum((test_data$total_jail_pop_rate - mean(test_data$total_jail_pop_rate))^2)
rsq <- 1 - rss/tss
print(paste("R-squared:", rsq))

# TUNING 
tuned_rf <- randomForest(total_jail_pop_rate ~ ., data = train_data, ntree = 500, mtry = 12)
print(tuned_rf)

# Predict and evaluate the tuned model
tuned_predictions <- predict(tuned_rf, test_data)
tuned_mse <- mean((tuned_predictions - test_data$total_jail_pop_rate)^2)
print(paste("Tuned Model Mean Squared Error:", tuned_mse))
```

